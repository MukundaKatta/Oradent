# Database
DATABASE_URL=postgresql://oradent:oradent@localhost:5432/oradent

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic (for AI features)
ANTHROPIC_API_KEY=

# Auth — JWT_SECRET must be at least 32 characters
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# CORS — comma-separated origins allowed in production
CORS_ORIGINS=http://localhost:3000

# Email (for appointment reminders)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@oradent.com

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50mb

# App
PORT=4000
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
